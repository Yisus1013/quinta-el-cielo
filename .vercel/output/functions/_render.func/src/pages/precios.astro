---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
---

<Layout title="Precios - Palapa El Sabino">
    <Navigation />

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-content-center">
            <h1 class="page-title">Precios</h1>
            <p class="page-subtitle">Tarifas por fin de semana (Viernes a Domingo)</p>
        </div>
    </section>

    <!-- Pricing Cards -->
    <section class="pricing-section">
        <div class="container">
            <div class="pricing-grid">
                <!-- Palapa Baja -->
                <div class="price-card">
                    <div class="price-header">
                        <h3 class="price-title">Planta Baja (Paraíso)</h3>
                        <p class="price-subtitle">Renta de planta baja, fin de semana completo</p>
                    </div>
                    <div class="price-amount">
                        <span class="currency">$</span>
                        <span class="number">5,499</span>
                        <span class="period">/fin de semana</span>
                    </div>
                    <ul class="price-features">
                        <li>2 habitaciones</li>
                        <li>Hasta 20 personas</li>
                        <li>Cocina equipada</li>
                        <li>Área común</li>
                        <li>Estacionamiento</li>
                    </ul>
                    <a href="/reservar" class="price-cta">Reservar</a>
                </div>

                <!-- Cabaña Completa -->
                <div class="price-card featured">
                    <div class="price-badge">Más popular</div>
                    <div class="price-header">
                        <h3 class="price-title">Cabaña Completa</h3>
                        <p class="price-subtitle">Planta Baja y Alta, fin de semana completo</p>
                    </div>
                    <div class="price-amount">
                        <span class="currency">$</span>
                        <span class="number">8,500</span>
                        <span class="period">/fin de semana</span>
                    </div>
                    <ul class="price-features">
                        <li>4 habitaciones</li>
                        <li>Hasta 20 personas</li>
                        <li>Cocina completa</li>
                        <li>Todas las áreas</li>
                        <li>Asador incluido</li>
                        <li>Vista panorámica</li>
                    </ul>
                    <a href="/reservar" class="price-cta price-cta--featured"
                        >Reservar</a
                    >
                </div>
            </div>
        </div>
    </section>

    <!-- Terms Section -->
    <section class="terms-section">
        <div class="container-narrow">
            <h2 class="section-title-center">Términos y condiciones</h2>
            <div class="terms-grid">
                <div class="term-item">
                    <h3 class="term-title">Check-in / Check-out</h3>
                    <p class="term-text">
                        Entrada: 3:00 PM<br />Salida: 12:00 PM
                    </p>
                </div>
                <div class="term-item">
                    <h3 class="term-title">Política de cancelación</h3>
                    <p class="term-text">
                        Cancelación gratuita hasta 7 días antes
                    </p>
                </div>
                <div class="term-item">
                    <h3 class="term-title">Depósito de garantía</h3>
                    <p class="term-text">$2,000 reembolsables</p>
                </div>
                <div class="term-item">
                    <h3 class="term-title">Mínimo de estancia</h3>
                    <p class="term-text">2 noches en fin de semana</p>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
        <div class="container-narrow">
            <h2 class="section-title-center">Preguntas frecuentes</h2>
            <div class="faq-list">
                <div class="faq-item">
                    <h3 class="faq-question">¿Qué incluye la tarifa?</h3>
                    <p class="faq-answer">
                        La tarifa incluye el uso completo de las instalaciones,
                        cocina equipada, áreas comunes, estacionamiento y todos
                        los servicios básicos.
                    </p>
                </div>
                <div class="faq-item">
                    <h3 class="faq-question">¿Puedo llevar mascotas?</h3>
                    <p class="faq-answer">
                        Sí, las mascotas son bienvenidas con un cargo adicional
                        de $500 por estadía. Máximo 2 mascotas por reservación.
                    </p>
                </div>
                <div class="faq-item">
                    <h3 class="faq-question">
                        ¿Hay descuentos por estadías largas?
                    </h3>
                    <p class="faq-answer">
                        Ofrecemos descuentos especiales para estadías de 7
                        noches o más. Contáctanos para más información.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
        <div class="container-narrow">
            <h2 class="cta-title">¿Listo para tu escape?</h2>
            <p class="cta-text">Reserva ahora y asegura tu fecha</p>
            <a href="/reservar" class="btn-primary">Ver disponibilidad</a>
        </div>
    </section>
</Layout>

<style>
    /* Hero Section */
    .hero-section {
        padding-top: 88px;
        min-height: 40vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fafafa;
    }

    .hero-content-center {
        text-align: center;
        padding: 4rem 1.5rem;
    }

    .page-title {
        font-size: clamp(3rem, 8vw, 5rem);
        font-weight: 800;
        line-height: 1;
        letter-spacing: -0.03em;
        color: #000;
        margin-bottom: 1.5rem;
    }

    .page-subtitle {
        font-size: 1.25rem;
        font-weight: 300;
        color: #737373;
        letter-spacing: 0.02em;
    }

    /* Pricing Section */
    .pricing-section {
        padding: 6rem 0;
        background: #fff;
    }

    .pricing-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 3rem;
        max-width: 900px;
        margin: 0 auto;
    }

    .price-card {
        position: relative;
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 0;
        padding: 3rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .price-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
    }

    .price-card.featured {
        border-color: #000;
    }

    .price-badge {
        position: absolute;
        top: -1px;
        right: -1px;
        background: #000;
        color: #fff;
        padding: 0.5rem 1.5rem;
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .price-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .price-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #000;
        margin-bottom: 0.5rem;
    }

    .price-subtitle {
        font-size: 0.938rem;
        color: #737373;
    }

    .price-amount {
        display: flex;
        align-items: baseline;
        justify-content: center;
        margin-bottom: 2rem;
        gap: 0.25rem;
    }

    .currency {
        font-size: 1.5rem;
        font-weight: 400;
        color: #737373;
    }

    .number {
        font-size: 3rem;
        font-weight: 700;
        color: #000;
        line-height: 1;
    }

    .period {
        font-size: 1rem;
        font-weight: 400;
        color: #737373;
    }

    .price-features {
        list-style: none;
        padding: 0;
        margin: 0 0 2rem 0;
    }

    .price-features li {
        padding: 0.75rem 0;
        border-bottom: 1px solid #f5f5f5;
        color: #525252;
        font-size: 0.938rem;
    }

    .price-features li:last-child {
        border-bottom: none;
    }

    .price-cta {
        display: block;
        width: 100%;
        padding: 1rem;
        background: transparent;
        color: #000;
        border: 1px solid #000;
        font-size: 1rem;
        font-weight: 500;
        text-align: center;
        text-decoration: none;
        border-radius: 100px;
        transition: all 0.2s;
    }

    .price-cta:hover {
        background: #000;
        color: #fff;
    }

    .price-cta--featured {
        background: #000;
        color: #fff;
    }

    .price-cta--featured:hover {
        background: #171717;
    }

    /* Terms Section */
    .terms-section {
        padding: 6rem 0;
        background: #fafafa;
    }

    .terms-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 3rem;
        margin-top: 3rem;
    }

    .term-item {
        text-align: center;
    }

    .term-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: #000;
        margin-bottom: 0.75rem;
    }

    .term-text {
        font-size: 0.938rem;
        color: #737373;
        line-height: 1.6;
    }

    /* FAQ Section */
    .faq-section {
        padding: 6rem 0;
        background: #fff;
    }

    .faq-list {
        margin-top: 3rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .faq-item {
        padding-bottom: 2rem;
        border-bottom: 1px solid #f5f5f5;
    }

    .faq-item:last-child {
        border-bottom: none;
    }

    .faq-question {
        font-size: 1.25rem;
        font-weight: 600;
        color: #000;
        margin-bottom: 1rem;
    }

    .faq-answer {
        font-size: 1rem;
        color: #737373;
        line-height: 1.7;
    }

    /* CTA Section */
    .cta-section {
        padding: 6rem 0;
        background: #fafafa;
        text-align: center;
    }

    .cta-title {
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.03em;
        color: #000;
        margin-bottom: 1.5rem;
    }

    .cta-text {
        font-size: 1.125rem;
        color: #737373;
        margin-bottom: 3rem;
    }

    .btn-primary {
        display: inline-block;
        padding: 1rem 3rem;
        background: #000;
        color: #fff;
        font-size: 1rem;
        font-weight: 500;
        border-radius: 100px;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-primary:hover {
        background: #171717;
        transform: translateY(-2px);
    }

    /* Utilities */
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    .container-narrow {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    .section-title-center {
        text-align: center;
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.03em;
        color: #000;
        margin-bottom: 2rem;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .hero-section {
            padding-top: 72px;
        }

        .pricing-grid {
            grid-template-columns: 1fr;
        }

        .terms-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .pricing-section,
        .terms-section,
        .faq-section,
        .cta-section {
            padding: 4rem 0;
        }
    }
</style>
