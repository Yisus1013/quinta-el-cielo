---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';

// Si ya está autenticado, redirigir
import { getUserFromCookies } from '../lib/auth';
const user = getUserFromCookies(Astro.cookies);
if (user) {
  return Astro.redirect('/');
}
---

<Layout title="Crear cuenta - Palapa El Sabino">
  <Navigation />

  <section class="min-h-screen flex items-center justify-center p-8 bg-cream">
    <div class="w-full max-w-md bg-white p-12 border border-sage-light md:p-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-3xl font-extrabold tracking-tight text-forest-dark mb-2">Crear cuenta</h1>
        <p class="text-base text-warm-gray font-normal">Únete para reservar tu estancia</p>
      </div>

      <!-- Error Message -->
      <div id="error-message" class="hidden"></div>

      <form id="registerForm" class="flex flex-col gap-6">
        <div class="flex flex-col gap-2">
          <label for="nombre" class="text-sm font-medium text-forest-dark tracking-wide">Nombre completo</label>
          <input
            type="text"
            id="nombre"
            name="nombre"
            required
            class="w-full py-3.5 text-base border-0 border-b border-sage-light bg-transparent transition-all duration-200 outline-none focus:border-sage placeholder:text-sage-light"
            placeholder="Juan Pérez"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="email" class="text-sm font-medium text-forest-dark tracking-wide">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full py-3.5 text-base border-0 border-b border-sage-light bg-transparent transition-all duration-200 outline-none focus:border-sage placeholder:text-sage-light"
            placeholder="tu@email.com"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="telefono" class="text-sm font-medium text-forest-dark tracking-wide">Teléfono</label>
          <input
            type="tel"
            id="telefono"
            name="telefono"
            required
            class="w-full py-3.5 text-base border-0 border-b border-sage-light bg-transparent transition-all duration-200 outline-none focus:border-sage placeholder:text-sage-light"
            placeholder="81 1234 5678"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="password" class="text-sm font-medium text-forest-dark tracking-wide">Contraseña</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            minlength="8"
            class="w-full py-3.5 text-base border-0 border-b border-sage-light bg-transparent transition-all duration-200 outline-none focus:border-sage placeholder:text-sage-light"
            placeholder="••••••••"
          />
          <span class="text-xs text-neutral-400">Mínimo 8 caracteres</span>
        </div>

        <div class="flex flex-col gap-2">
          <label for="confirmPassword" class="text-sm font-medium text-forest-dark tracking-wide">Confirmar contraseña</label>
          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            required
            class="w-full py-3.5 text-base border-0 border-b border-sage-light bg-transparent transition-all duration-200 outline-none focus:border-sage placeholder:text-sage-light"
            placeholder="••••••••"
          />
        </div>

        <button type="submit" id="submit-button" class="mt-8 px-4 py-4 bg-sage text-white text-base font-medium border-none rounded-full cursor-pointer transition-all duration-200 hover:bg-moss hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed">
          Crear cuenta
        </button>
      </form>

      <div class="mt-12 text-center flex items-center justify-center gap-2">
        <span class="text-sm text-warm-gray">¿Ya tienes cuenta?</span>
        <a href="/login" class="text-sm text-forest-dark font-medium no-underline transition-opacity duration-200 hover:opacity-70">Inicia sesión</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  #error-message:not(.hidden) {
    background-color: #fef2f2; /* bg-red-50 */
    color: #dc2626; /* text-red-600 */
    padding: 1rem; /* p-4 */
    margin-bottom: 2rem; /* mb-8 */
    font-size: 0.875rem; /* text-sm */
    text-align: center;
  }
</style>

<script>
  const form = document.getElementById('registerForm') as HTMLFormElement;
  const errorDiv = document.getElementById('error-message');
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const confirmPasswordInput = document.getElementById('confirmPassword') as HTMLInputElement;

  // Password match validation
  confirmPasswordInput?.addEventListener('input', () => {
    if (confirmPasswordInput.value && passwordInput.value !== confirmPasswordInput.value) {
      confirmPasswordInput.setCustomValidity('Las contraseñas no coinciden');
    } else {
      confirmPasswordInput.setCustomValidity('');
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Clear previous errors
    if (errorDiv) {
      errorDiv.classList.add('hidden');
      errorDiv.textContent = '';
    }

    // Validate passwords match
    if (passwordInput.value !== confirmPasswordInput.value) {
      if (errorDiv) {
        errorDiv.textContent = 'Las contraseñas no coinciden';
        errorDiv.classList.remove('hidden');
      }
      return;
    }

    // Show loading state
    submitButton.disabled = true;
    const originalText = submitButton.textContent;
    submitButton.innerHTML = '<span class="inline-block w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></span>';

    const formData = new FormData(form);
    const data = {
      nombre: formData.get('nombre'),
      email: formData.get('email'),
      telefono: formData.get('telefono'),
      password: formData.get('password')
    };

    try {
      const response = await fetch('/api/auth/register', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      });

      const result = await response.json();

      if (!response.ok) {
        throw new Error(result.error || 'Error al crear la cuenta');
      }

      // Success - redirect to login
      window.location.href = '/login?registered=true';
    } catch (error) {
      // Reset button
      submitButton.disabled = false;
      submitButton.textContent = originalText;

      // Show error
      if (errorDiv) {
        errorDiv.textContent = error instanceof Error ? error.message : 'Error al crear la cuenta';
        errorDiv.classList.remove('hidden');
      }
    }
  });
</script>
