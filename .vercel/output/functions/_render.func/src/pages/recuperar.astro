---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';

// Si ya está autenticado, redirigir
import { getUserFromCookies } from '../lib/auth';
const user = getUserFromCookies(Astro.cookies);
if (user) {
  return Astro.redirect('/');
}
---

<Layout title="Recuperar contraseña - Palapa El Sabino">
  <Navigation />

  <section class="min-h-screen flex items-center justify-center p-8 bg-cream">
    <div class="w-full max-w-md bg-white p-12 border border-sage-light md:p-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-3xl font-extrabold tracking-tight text-forest-dark mb-2">¿Olvidaste tu contraseña?</h1>
        <p class="text-base text-warm-gray font-normal">Te enviaremos instrucciones para restablecerla</p>
      </div>

      <!-- Success Message (hidden initially) -->
      <div id="success-message" class="hidden text-center p-8 bg-green-50 border border-green-300 mb-8">
        <h2 class="text-xl font-semibold text-green-800 mb-2">Correo enviado</h2>
        <p class="text-sm text-green-600 mb-6">
          Revisa tu bandeja de entrada. Si tienes una cuenta con nosotros,
          recibirás un enlace para restablecer tu contraseña.
        </p>
        <a href="/login" class="inline-block text-sm text-forest-dark font-medium no-underline transition-opacity duration-200 hover:opacity-70">Volver a iniciar sesión</a>
      </div>

      <!-- Error Message -->
      <div id="error-message" class="hidden"></div>

      <!-- Form -->
      <form id="resetForm" class="flex flex-col gap-6">
        <div class="flex flex-col gap-2">
          <label for="email" class="text-sm font-medium text-forest-dark tracking-wide">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full py-3.5 text-base border-0 border-b border-sage-light bg-transparent transition-all duration-200 outline-none focus:border-sage placeholder:text-sage-light"
            placeholder="tu@email.com"
          />
        </div>

        <button type="submit" id="submit-button" class="mt-8 px-4 py-4 bg-sage text-white text-base font-medium border-none rounded-full cursor-pointer transition-all duration-200 hover:bg-moss hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed">
          Enviar instrucciones
        </button>
      </form>

      <div class="mt-12 text-center flex items-center justify-center gap-4" id="footer-links">
        <a href="/login" class="text-sm text-warm-gray no-underline transition-colors duration-200 hover:text-forest-dark">Volver a iniciar sesión</a>
        <span class="text-sage-light text-sm">·</span>
        <a href="/registro" class="text-sm text-warm-gray no-underline transition-colors duration-200 hover:text-forest-dark">Crear cuenta</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  #error-message:not(.hidden) {
    background-color: #fef2f2; /* bg-red-50 */
    color: #dc2626; /* text-red-600 */
    padding: 1rem; /* p-4 */
    margin-bottom: 2rem; /* mb-8 */
    font-size: 0.875rem; /* text-sm */
    text-align: center;
  }
</style>

<script>
  const form = document.getElementById('resetForm') as HTMLFormElement;
  const errorDiv = document.getElementById('error-message');
  const successDiv = document.getElementById('success-message');
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
  const footerLinks = document.getElementById('footer-links');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Clear previous messages
    if (errorDiv) {
      errorDiv.classList.add('hidden');
      errorDiv.textContent = '';
    }

    // Show loading state
    submitButton.disabled = true;
    const originalText = submitButton.textContent;
    submitButton.innerHTML = '<span class="inline-block w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></span>';

    // Simulate API call (in production, this would send an actual request)
    setTimeout(() => {
      // Hide form and footer
      form.classList.add('hidden');
      footerLinks?.classList.add('hidden');

      // Show success message
      if (successDiv) {
        successDiv.classList.remove('hidden');
      }

      // Reset button (though it's hidden)
      submitButton.disabled = false;
      submitButton.textContent = originalText;
    }, 1500);
  });
</script>
