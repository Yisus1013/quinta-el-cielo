---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Gallery from '../components/Gallery.astro';
import Amenities from '../components/Amenities.astro';
---

<Layout title="Palapa El Sabino - Refugio de Lujo en la Sierra">
	<Hero />

	<!-- Experiencia Section -->
	<section id="experiencia" class="section-padding bg-pearl">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid lg:grid-cols-2 gap-16 items-center">
				<!-- Content -->
				<div class="space-y-6">
					<span class="text-sm font-semibold text-sage uppercase tracking-wider">Experiencia Única</span>
					<h2 class="text-4xl md:text-5xl font-display font-bold text-forest-dark leading-tight">
						Un refugio donde la naturaleza abraza el lujo
					</h2>
					<p class="text-lg text-warm-gray leading-relaxed">
						Ubicada a 3,550 metros de altitud en la majestuosa Sierra de Arteaga,
						nuestra cabaña ofrece una experiencia sin igual. Vistas panorámicas que
						cortan el aliento, aire puro de montaña y un diseño que respeta la
						naturaleza mientras ofrece todas las comodidades modernas.
					</p>
					<p class="text-lg text-warm-gray leading-relaxed">
						Cada rincón ha sido pensado para brindarte momentos de desconexión
						absoluta, donde el tiempo se detiene y lo único que importa es estar
						presente.
					</p>

					<!-- Stats Grid -->
					<div class="grid grid-cols-2 gap-6 pt-8">
						<div class="p-6 gradient-cream-stone rounded-2xl border border-sage-light">
							<div class="text-4xl font-bold text-sage mb-2">4</div>
							<div class="text-sm text-forest-dark uppercase tracking-wide">Habitaciones Amplias</div>
						</div>
						<div class="p-6 gradient-cream-stone rounded-2xl border border-sage-light">
							<div class="text-4xl font-bold text-sage mb-2">20</div>
							<div class="text-sm text-forest-dark uppercase tracking-wide">Huéspedes Máximo</div>
						</div>
						<div class="p-6 gradient-cream-stone rounded-2xl border border-sage-light">
							<div class="text-4xl font-bold text-sage mb-2">2</div>
							<div class="text-sm text-forest-dark uppercase tracking-wide">Palapas Exteriores</div>
						</div>
						<div class="p-6 gradient-cream-stone rounded-2xl border border-sage-light">
							<div class="text-4xl font-bold text-sage mb-2">80</div>
							<div class="text-sm text-forest-dark uppercase tracking-wide">Min desde MTY</div>
						</div>
					</div>

					<a href="/cabana" class="inline-block mt-8 btn-primary">
						Explorar la Cabaña
					</a>
				</div>

				<!-- Image -->
				<div class="relative h-[600px] rounded-2xl overflow-hidden shadow-2xl">
					<img
						src="/images/WhatsApp Image 2026-03-03 at 4.26.26 PM (1).jpeg"
						alt="Interior de Palapa El Sabino"
						class="w-full h-full object-cover"
					/>
				</div>
			</div>
		</div>
	</section>

	<!-- Amenidades Section -->
	<section id="amenidades" class="section-padding bg-cream">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<span class="text-sm font-semibold text-sage uppercase tracking-wider">Comodidades Premium</span>
				<h2 class="mt-4 text-4xl md:text-5xl font-display font-bold text-forest-dark">
					Todo lo que necesitas,<br class="hidden sm:block"/>nada que sobre
				</h2>
			</div>
			<Amenities />
		</div>
	</section>

	<!-- Gallery Section -->
	<section class="section-padding bg-pearl">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<span class="text-sm font-semibold text-sage uppercase tracking-wider">Galería Visual</span>
				<h2 class="mt-4 text-4xl md:text-5xl font-display font-bold text-forest-dark">
					Donde cada vista<br class="hidden sm:block"/>cuenta una historia
				</h2>
			</div>
			<Gallery />
		</div>
	</section>

	<!-- Testimonials Section -->
	<section class="section-padding bg-cream">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16">
				<span class="text-sm font-semibold text-sage uppercase tracking-wider">Testimonios</span>
				<h2 class="mt-4 text-4xl md:text-5xl font-display font-bold text-forest-dark">
					Palabras de quienes<br class="hidden sm:block"/>vivieron la experiencia
				</h2>
			</div>

			<div class="grid md:grid-cols-3 gap-8">
				<div class="p-8 gradient-cream-stone rounded-2xl shadow-lg hover:shadow-2xl transition-all hover:scale-[1.02] border border-sage-light">
					<div class="text-amber text-2xl mb-4">
						★★★★★
					</div>
					<p class="text-warm-gray italic mb-6 leading-relaxed">
						"Una experiencia transformadora. La cabaña supera todas las expectativas
						con sus vistas impresionantes y un nivel de comodidad excepcional. El
						lugar perfecto para reconectar con la naturaleza sin renunciar al lujo."
					</p>
					<div class="border-t border-sage-light pt-4">
						<div class="font-semibold text-forest-dark">María González</div>
						<div class="text-sm text-warm-gray">Monterrey, México</div>
					</div>
				</div>

				<div class="p-8 gradient-cream-stone rounded-2xl shadow-lg hover:shadow-2xl transition-all hover:scale-[1.02] border border-sage-light">
					<div class="text-amber text-2xl mb-4">
						★★★★★
					</div>
					<p class="text-warm-gray italic mb-6 leading-relaxed">
						"Pasamos un fin de semana increíble. La atención al detalle es
						impresionante, desde la arquitectura hasta los servicios. Las vistas son
						simplemente espectaculares. ¡Volveremos sin duda!"
					</p>
					<div class="border-t border-sage-light pt-4">
						<div class="font-semibold text-forest-dark">Carlos Martínez</div>
						<div class="text-sm text-warm-gray">San Pedro, N.L.</div>
					</div>
				</div>

				<div class="p-8 gradient-cream-stone rounded-2xl shadow-lg hover:shadow-2xl transition-all hover:scale-[1.02] border border-sage-light">
					<div class="text-amber text-2xl mb-4">
						★★★★★
					</div>
					<p class="text-warm-gray italic mb-6 leading-relaxed">
						"El escape perfecto de la ciudad. Aire puro, tranquilidad absoluta y un
						servicio de primera. La cabaña está equipada con todo lo necesario para
						una estadía confortable. Altamente recomendable."
					</p>
					<div class="border-t border-sage-light pt-4">
						<div class="font-semibold text-forest-dark">Ana Sofía Reyes</div>
						<div class="text-sm text-warm-gray">Ciudad de México</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Final Section -->
	<section class="relative overflow-hidden">
		<div class="grid lg:grid-cols-2 min-h-[80vh]">
			<!-- Content Side -->
			<div class="gradient-forest-sage text-cream flex items-center justify-center p-12 lg:p-20">
				<div class="max-w-xl">
					<span class="text-sm font-semibold text-amber uppercase tracking-wider">Disponibilidad Limitada</span>
					<h2 class="mt-6 text-5xl md:text-6xl font-display font-bold leading-tight mb-6">
						Comienza tu<br/>escape perfecto
					</h2>
					<p class="text-xl text-cream/90 mb-10">
						Reserva tu experiencia única en las alturas.
						Cada momento cuenta.
					</p>
					<div class="flex flex-col sm:flex-row gap-4">
						<a href="/reservar" class="btn-secondary text-center">
							Ver Disponibilidad
						</a>
						<a href="tel:+528110000000" class="px-8 py-4 bg-cream/10 backdrop-blur-sm text-cream border border-cream/30 rounded-full font-medium text-center transition-all hover:bg-cream/20">
							Llamar Ahora
						</a>
					</div>
				</div>
			</div>

			<!-- Image Side -->
			<div class="relative min-h-[400px] lg:min-h-0">
				<img
					src="/images/WhatsApp Image 2026-03-03 at 4.26.26 PM (5).jpeg"
					alt="Atardecer en Palapa El Sabino"
					class="absolute inset-0 w-full h-full object-cover"
				/>
			</div>
		</div>
	</section>
</Layout>
