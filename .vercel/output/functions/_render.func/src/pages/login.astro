---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';

// Si ya está autenticado, redirigir
import { getUserFromCookies } from '../lib/auth';
const user = getUserFromCookies(Astro.cookies);
if (user) {
  const redirect = Astro.url.searchParams.get('redirect') || '/';
  return Astro.redirect(redirect);
}
---

<Layout title="Acceder - Palapa El Sabino">
  <Navigation />

  <section class="min-h-screen flex items-center justify-center p-8 bg-cream">
    <div class="w-full max-w-md bg-white p-12 border border-sage-light md:p-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-3xl font-extrabold tracking-tight text-forest-dark mb-2">Bienvenido</h1>
        <p class="text-base text-warm-gray font-normal">Accede a tu cuenta</p>
      </div>

      <!-- Error Message -->
      <div id="error-message" class="hidden"></div>

      <form id="loginForm" class="flex flex-col gap-6">
        <div class="flex flex-col gap-2">
          <label for="email" class="text-sm font-medium text-forest-dark tracking-wide">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full py-3.5 text-base border-0 border-b border-sage-light bg-transparent transition-all duration-200 outline-none focus:border-sage placeholder:text-warm-gray/40"
            placeholder="tu@email.com"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="password" class="text-sm font-medium text-forest-dark tracking-wide">Contraseña</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            class="w-full py-3.5 text-base border-0 border-b border-sage-light bg-transparent transition-all duration-200 outline-none focus:border-sage placeholder:text-warm-gray/40"
            placeholder="••••••••"
          />
        </div>

        <button type="submit" id="submit-button" class="mt-8 px-4 py-4 bg-sage text-white text-base font-medium border-none rounded-full cursor-pointer transition-all duration-200 hover:bg-moss hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed">
          Iniciar sesión
        </button>
      </form>

      <div class="mt-12 text-center flex items-center justify-center gap-4">
        <a href="/recuperar" class="text-sm text-warm-gray no-underline transition-colors duration-200 hover:text-sage">¿Olvidaste tu contraseña?</a>
        <span class="text-sage-light text-sm">·</span>
        <a href="/registro" class="text-sm text-warm-gray no-underline transition-colors duration-200 hover:text-sage">Crear cuenta</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  #error-message:not(.hidden) {
    background-color: #fef2f2; /* bg-red-50 */
    color: #dc2626; /* text-red-600 */
    padding: 1rem; /* p-4 */
    margin-bottom: 2rem; /* mb-8 */
    font-size: 0.875rem; /* text-sm */
    text-align: center;
  }
</style>

<script>
  const form = document.getElementById('loginForm') as HTMLFormElement;
  const errorDiv = document.getElementById('error-message');
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Clear previous errors
    if (errorDiv) {
      errorDiv.classList.add('hidden');
      errorDiv.textContent = '';
    }

    // Show loading state
    submitButton.disabled = true;
    const originalText = submitButton.textContent;
    submitButton.innerHTML = '<span class="inline-block w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></span>';

    const formData = new FormData(form);
    const data = {
      email: formData.get('email'),
      password: formData.get('password')
    };

    try {
      const response = await fetch('/api/auth/login', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      });

      const result = await response.json();

      if (!response.ok) {
        throw new Error(result.error || 'Credenciales incorrectas');
      }

      // Success - redirect
      const params = new URLSearchParams(window.location.search);
      const redirect = params.get('redirect') || '/';
      window.location.href = redirect;
    } catch (error) {
      // Reset button
      submitButton.disabled = false;
      submitButton.textContent = originalText;

      // Show error
      if (errorDiv) {
        errorDiv.textContent = error instanceof Error ? error.message : 'Error al iniciar sesión';
        errorDiv.classList.remove('hidden');
      }
    }
  });
</script>
