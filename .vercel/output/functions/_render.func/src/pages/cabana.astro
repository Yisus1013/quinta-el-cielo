---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Gallery from '../components/Gallery.astro';
---

<Layout title="La Cabaña - Palapa El Sabino">
  <Navigation />

  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-content-center">
      <h1 class="page-title">La Cabaña</h1>
      <p class="page-subtitle">Un refugio único en la montaña</p>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-number">3,550m</span>
          <span class="stat-label">Altitud</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">20</span>
          <span class="stat-label">Huéspedes</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">4</span>
          <span class="stat-label">Habitaciones</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">80min</span>
          <span class="stat-label">De Monterrey</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Description -->
  <section class="content-section">
    <div class="container-narrow">
      <div class="content-grid">
        <div class="content-block">
          <h2 class="section-title">Diseñada para el confort</h2>
          <p class="section-text">
            Ubicada en la Sierra de Arteaga, nuestra cabaña combina la belleza natural
            con todas las comodidades modernas. Perfecta para reuniones familiares,
            retiros de amigos o escapadas especiales.
          </p>
        </div>
        <div class="content-block">
          <h2 class="section-title">Vistas espectaculares</h2>
          <p class="section-text">
            A 3,550 metros de altitud, disfruta de un cielo estrellado único,
            rodeado de flora y fauna nativa, con paisajes que te dejarán sin aliento.
          </p>
        </div>
        <div class="content-block">
          <h2 class="section-title">Acceso fácil</h2>
          <p class="section-text">
            A solo 80 minutos del centro de Monterrey, con camino de concreto
            hidráulico que permite el acceso con cualquier tipo de vehículo.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <Gallery />

  <!-- Amenities Grid -->
  <section class="amenities-section">
    <div class="container">
      <h2 class="section-title-center">Amenidades</h2>
      <div class="amenities-grid">
        <div class="amenity-item">
          <h3 class="amenity-title">Cocina completa</h3>
          <p class="amenity-text">Equipada con todo lo necesario</p>
        </div>
        <div class="amenity-item">
          <h3 class="amenity-title">Asador</h3>
          <p class="amenity-text">Perfecto para reuniones</p>
        </div>
        <div class="amenity-item">
          <h3 class="amenity-title">Chimenea</h3>
          <p class="amenity-text">Calidez en las noches frías</p>
        </div>
        <div class="amenity-item">
          <h3 class="amenity-title">Áreas verdes</h3>
          <p class="amenity-text">Espacios para relajarse</p>
        </div>
        <div class="amenity-item">
          <h3 class="amenity-title">Vista panorámica</h3>
          <p class="amenity-text">360° de naturaleza</p>
        </div>
        <div class="amenity-item">
          <h3 class="amenity-title">Estacionamiento</h3>
          <p class="amenity-text">Amplio y seguro</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container-narrow">
      <h2 class="cta-title">¿Listo para reservar?</h2>
      <p class="cta-text">Consulta disponibilidad y precios</p>
      <div class="cta-buttons">
        <a href="/precios" class="btn-secondary">Ver precios</a>
        <a href="/reservar" class="btn-primary">Reservar ahora</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero-section {
    padding-top: 88px;
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fafafa;
  }

  .hero-content-center {
    text-align: center;
    padding: 4rem 1.5rem;
  }

  .page-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    color: #000;
    margin-bottom: 1.5rem;
  }

  .page-subtitle {
    font-size: 1.25rem;
    font-weight: 300;
    color: #737373;
    letter-spacing: 0.02em;
  }

  /* Stats Section */
  .stats-section {
    padding: 5rem 0;
    background: #fff;
    border-top: 1px solid #f5f5f5;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stat-number {
    font-size: 3rem;
    font-weight: 700;
    color: #000;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.875rem;
    font-weight: 400;
    color: #737373;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Content Section */
  .content-section {
    padding: 6rem 0;
    background: #fff;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  .content-block {
    max-width: 600px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #000;
    margin-bottom: 1rem;
  }

  .section-title-center {
    text-align: center;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    color: #000;
    margin-bottom: 4rem;
  }

  .section-text {
    font-size: 1.125rem;
    line-height: 1.7;
    color: #737373;
  }

  /* Amenities Section */
  .amenities-section {
    padding: 6rem 0;
    background: #fafafa;
  }

  .amenities-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }

  .amenity-item {
    text-align: center;
    padding: 2rem;
  }

  .amenity-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #000;
    margin-bottom: 0.5rem;
  }

  .amenity-text {
    font-size: 0.938rem;
    color: #737373;
  }

  /* CTA Section */
  .cta-section {
    padding: 6rem 0;
    background: #fff;
    text-align: center;
  }

  .cta-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    color: #000;
    margin-bottom: 1.5rem;
  }

  .cta-text {
    font-size: 1.125rem;
    color: #737373;
    margin-bottom: 3rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    padding: 1rem 3rem;
    background: #000;
    color: #fff;
    font-size: 1rem;
    font-weight: 500;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-primary:hover {
    background: #171717;
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-block;
    padding: 1rem 3rem;
    background: transparent;
    color: #000;
    font-size: 1rem;
    font-weight: 500;
    border: 1px solid #e5e5e5;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    background: #fafafa;
    border-color: #000;
  }

  /* Container */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .container-narrow {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .amenities-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding-top: 72px;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .stat-number {
      font-size: 2.5rem;
    }

    .amenities-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .content-section,
    .amenities-section,
    .cta-section {
      padding: 4rem 0;
    }
  }
</style>