---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import BookingCalendar from '../components/BookingCalendar.astro';
import { getUserFromCookies } from '../lib/auth';
import { CalendarClock, Home, CheckCircle } from 'lucide-astro';

const user = getUserFromCookies(Astro.cookies);

// Si no está autenticado, redirigir a login
if (!user) {
    return Astro.redirect('/login?redirect=/reservar');
}
---

<Layout title="Reservar - Quinta El Cielo">
    <Navigation slot="nav" />

    <section class="py-20 md:py-32 bg-gradient-to-b from-bone to-white min-h-screen">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Header -->
            <div class="text-center mb-12">
                <span class="text-sm font-semibold text-sunset uppercase tracking-wider">
                    Reserva tu Experiencia
                </span>
                <h1 class="mt-4 text-4xl md:text-5xl font-bold text-night mb-4">
                    Comienza tu Aventura en las Alturas
                </h1>
                <p class="text-lg text-night/70 max-w-2xl mx-auto">
                    Selecciona las fechas de tu estadía y prepárate para una experiencia inolvidable
                    en la Sierra de Arteaga a 3,550m sobre el nivel del mar.
                </p>
            </div>

            <!-- Booking Calendar Component -->
            <BookingCalendar />

            <!-- Info Section -->
            <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
                <div class="text-center p-6 bg-white rounded-xl border border-gray-100 hover:border-forest/30 transition-colors">
                    <div class="w-14 h-14 bg-gradient-to-br from-forest/10 to-forest/5 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <CalendarClock class="w-7 h-7 text-forest" />
                    </div>
                    <h3 class="font-bold text-night mb-2">Check-in Viernes</h3>
                    <p class="text-sm text-night/60">A partir de las 4:00 PM</p>
                </div>

                <div class="text-center p-6 bg-white rounded-xl border border-gray-100 hover:border-sunset/30 transition-colors">
                    <div class="w-14 h-14 bg-gradient-to-br from-sunset/10 to-sunset/5 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <Home class="w-7 h-7 text-sunset" />
                    </div>
                    <h3 class="font-bold text-night mb-2">Check-out Domingo</h3>
                    <p class="text-sm text-night/60">Hasta las 2:00 PM</p>
                </div>

                <div class="text-center p-6 bg-white rounded-xl border border-gray-100 hover:border-forest/30 transition-colors">
                    <div class="w-14 h-14 bg-gradient-to-br from-forest/10 to-forest/5 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <CheckCircle class="w-7 h-7 text-forest" />
                    </div>
                    <h3 class="font-bold text-night mb-2">Confirmación</h3>
                    <p class="text-sm text-night/60">Te contactaremos en 24 horas</p>
                </div>
            </div>

            <!-- Cancellation Policy -->
            <div class="mt-12 max-w-4xl mx-auto bg-white rounded-xl p-6 border border-gray-200">
                <h3 class="font-bold text-night mb-3">Política de Reservación</h3>
                <ul class="space-y-2 text-sm text-night/70">
                    <li>• Las reservas están sujetas a disponibilidad y confirmación.</li>
                    <li>• Se requiere un depósito del 50% para confirmar tu reserva.</li>
                    <li>• Cancellaciones con más de 7 días de anticipación: reembolso del 80%.</li>
                    <li>• Cancellaciones con menos de 7 días: sin reembolso.</li>
                    <li>• El saldo restante debe pagarse al momento del check-in.</li>
                </ul>
            </div>
        </div>
    </section>

    <Footer slot="footer" />
</Layout>
