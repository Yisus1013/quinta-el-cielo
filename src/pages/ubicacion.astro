---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout title="Ubicación - Palapa El Sabino">
  <Navigation />

  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-content-center">
      <h1 class="page-title">Ubicación</h1>
      <p class="page-subtitle">Sierra de Arteaga, Coahuila</p>
    </div>
  </section>

  <!-- Map Section -->
  <section class="map-section">
    <div class="container">
      <div class="map-container">
        <!-- Placeholder for Google Maps iframe -->
        <div class="map-placeholder">
          <div class="map-content">
            <h2 class="map-title">Mapa Interactivo</h2>
            <p class="map-text">
              Cabaña Quinta El Cielo<br/>
              Sierra de Arteaga, Coahuila
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Info Section -->
  <section class="info-section">
    <div class="container">
      <div class="info-grid">
        <!-- Directions -->
        <div class="info-card">
          <h3 class="info-title">Cómo llegar</h3>
          <div class="directions-content">
            <h4 class="direction-subtitle">Desde Monterrey</h4>
            <ol class="direction-list">
              <li>Tomar la carretera hacia Saltillo</li>
              <li>Salir en Arteaga</li>
              <li>Seguir las señalizaciones hacia la sierra</li>
              <li>El camino está pavimentado hasta la cabaña</li>
            </ol>
            <p class="direction-time">Tiempo aproximado: 80 minutos</p>
          </div>
        </div>

        <!-- Details -->
        <div class="info-card">
          <h3 class="info-title">Detalles importantes</h3>
          <ul class="details-list">
            <li>
              <span class="detail-label">Altitud:</span>
              <span class="detail-value">3,550 metros sobre el nivel del mar</span>
            </li>
            <li>
              <span class="detail-label">Acceso:</span>
              <span class="detail-value">Camino de concreto hidráulico</span>
            </li>
            <li>
              <span class="detail-label">Vehículo:</span>
              <span class="detail-value">Apto para cualquier tipo de auto</span>
            </li>
            <li>
              <span class="detail-label">Señal:</span>
              <span class="detail-value">Cobertura limitada de celular</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Tips Section -->
  <section class="tips-section">
    <div class="container-narrow">
      <h2 class="section-title-center">Recomendaciones</h2>
      <div class="tips-grid">
        <div class="tip-item">
          <h3 class="tip-title">Qué traer</h3>
          <p class="tip-text">
            Ropa abrigadora para las noches, bloqueador solar,
            y provisiones adicionales si planeas una estadía larga.
          </p>
        </div>
        <div class="tip-item">
          <h3 class="tip-title">Clima</h3>
          <p class="tip-text">
            Temperaturas frescas todo el año. Las noches pueden ser
            muy frías, especialmente en invierno.
          </p>
        </div>
        <div class="tip-item">
          <h3 class="tip-title">Actividades</h3>
          <p class="tip-text">
            Senderismo, observación de estrellas, fotografía de paisajes,
            y descanso en un entorno natural único.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container-narrow">
      <h2 class="cta-title">¿Listo para visitarnos?</h2>
      <p class="cta-text">Reserva tu estancia en este paraíso natural</p>
      <div class="cta-buttons">
        <a href="/reservar" class="btn-primary">Reservar ahora</a>
        <a href="/cabana" class="btn-secondary">Ver la cabaña</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero-section {
    padding-top: 88px;
    min-height: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fafafa;
  }

  .hero-content-center {
    text-align: center;
    padding: 4rem 1.5rem;
  }

  .page-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    color: #000;
    margin-bottom: 1.5rem;
  }

  .page-subtitle {
    font-size: 1.25rem;
    font-weight: 300;
    color: #737373;
    letter-spacing: 0.02em;
  }

  /* Map Section */
  .map-section {
    padding: 0;
    background: #fff;
  }

  .map-container {
    width: 100%;
    aspect-ratio: 16/9;
    background: #f5f5f5;
    position: relative;
    overflow: hidden;
  }

  .map-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #fafafa 0%, #e5e5e5 100%);
  }

  .map-content {
    text-align: center;
  }

  .map-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #000;
    margin-bottom: 0.5rem;
  }

  .map-text {
    font-size: 0.938rem;
    color: #737373;
    line-height: 1.6;
  }

  /* Info Section */
  .info-section {
    padding: 6rem 0;
    background: #fff;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4rem;
  }

  .info-card {
    padding: 0;
  }

  .info-title {
    font-size: 2rem;
    font-weight: 700;
    color: #000;
    margin-bottom: 2rem;
  }

  .directions-content {
    space-y: 1.5rem;
  }

  .direction-subtitle {
    font-size: 1rem;
    font-weight: 600;
    color: #000;
    margin-bottom: 1rem;
  }

  .direction-list {
    list-style: none;
    counter-reset: step-counter;
    padding: 0;
    margin: 0 0 1.5rem 0;
  }

  .direction-list li {
    counter-increment: step-counter;
    padding: 0.75rem 0;
    border-bottom: 1px solid #f5f5f5;
    color: #525252;
    font-size: 0.938rem;
    position: relative;
    padding-left: 2rem;
  }

  .direction-list li::before {
    content: counter(step-counter);
    position: absolute;
    left: 0;
    font-weight: 600;
    color: #000;
  }

  .direction-time {
    font-size: 0.938rem;
    color: #737373;
    font-weight: 500;
    margin-top: 1.5rem;
  }

  .details-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .details-list li {
    display: flex;
    justify-content: space-between;
    padding: 1rem 0;
    border-bottom: 1px solid #f5f5f5;
  }

  .details-list li:last-child {
    border-bottom: none;
  }

  .detail-label {
    font-size: 0.938rem;
    font-weight: 600;
    color: #000;
  }

  .detail-value {
    font-size: 0.938rem;
    color: #737373;
    text-align: right;
  }

  /* Tips Section */
  .tips-section {
    padding: 6rem 0;
    background: #fafafa;
  }

  .tips-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-top: 3rem;
  }

  .tip-item {
    text-align: center;
  }

  .tip-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #000;
    margin-bottom: 1rem;
  }

  .tip-text {
    font-size: 0.938rem;
    color: #737373;
    line-height: 1.6;
  }

  /* CTA Section */
  .cta-section {
    padding: 6rem 0;
    background: #fff;
    text-align: center;
  }

  .cta-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    color: #000;
    margin-bottom: 1.5rem;
  }

  .cta-text {
    font-size: 1.125rem;
    color: #737373;
    margin-bottom: 3rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    padding: 1rem 3rem;
    background: #000;
    color: #fff;
    font-size: 1rem;
    font-weight: 500;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-primary:hover {
    background: #171717;
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-block;
    padding: 1rem 3rem;
    background: transparent;
    color: #000;
    font-size: 1rem;
    font-weight: 500;
    border: 1px solid #e5e5e5;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    background: #fafafa;
    border-color: #000;
  }

  /* Utilities */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .container-narrow {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title-center {
    text-align: center;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    color: #000;
    margin-bottom: 2rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-section {
      padding-top: 72px;
    }

    .info-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .tips-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .info-section,
    .tips-section,
    .cta-section {
      padding: 4rem 0;
    }
  }
</style>