---
import AuthLayout from '../layouts/AuthLayout.astro';
import { getUserFromCookies } from '../lib/auth';
import { ArrowLeft, User, Mail, Phone, Lock } from 'lucide-astro';

// Si ya está autenticado, redirigir
const user = getUserFromCookies(Astro.cookies);
if (user) {
  return Astro.redirect('/');
}
---

<AuthLayout title="Registrarse - Quinta El Cielo">
    <section class="min-h-screen flex items-center justify-center px-4 bg-gradient-to-br from-gray-50 to-gray-100 relative overflow-hidden py-12">
        <!-- Background decoration -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none">
            <div class="absolute -top-40 -right-40 w-80 h-80 bg-black/5 rounded-full blur-3xl"></div>
            <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-black/5 rounded-full blur-3xl"></div>
        </div>

        <div class="w-full max-w-md relative z-10">
            <!-- Back button -->
            <a href="/" class="inline-flex items-center gap-2 text-sm text-night/60 hover:text-night mb-8 transition-colors group">
                <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
                Volver al inicio
            </a>

            <!-- Card -->
            <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">
                <!-- Header with logo -->
                <div class="bg-gradient-to-br from-black to-gray-800 px-8 pt-12 pb-8 text-center">
                    <div class="flex justify-center mb-6">
                        <div class="w-24 h-24 bg-white rounded-2xl p-4 shadow-lg">
                            <img src="/logo.png" alt="Quinta El Cielo" class="w-full h-full object-contain" />
                        </div>
                    </div>
                    <h1 class="text-3xl font-bold text-white mb-2">Crear Cuenta</h1>
                    <p class="text-white/70">Únete a Quinta El Cielo</p>
                </div>

                <!-- Form -->
                <div class="p-8">
                    <!-- Error Message -->
                    <div id="error-message" class="hidden mb-6 p-4 bg-red-50 border-l-4 border-red-500 rounded-r-lg">
                        <p class="text-red-700 text-sm font-medium"></p>
                    </div>

                    <form id="registerForm" class="space-y-4">
                        <!-- Nombre -->
                        <div>
                            <label for="nombre" class="block text-sm font-semibold text-night mb-2">Nombre completo</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <User class="w-5 h-5 text-gray-400" />
                                </div>
                                <input
                                    type="text"
                                    id="nombre"
                                    name="nombre"
                                    required
                                    class="w-full pl-12 pr-4 py-3.5 border-2 border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-black focus:border-black transition-all"
                                    placeholder="Juan Pérez"
                                />
                            </div>
                        </div>

                        <!-- Email -->
                        <div>
                            <label for="email" class="block text-sm font-semibold text-night mb-2">Email</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <Mail class="w-5 h-5 text-gray-400" />
                                </div>
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    required
                                    class="w-full pl-12 pr-4 py-3.5 border-2 border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-black focus:border-black transition-all"
                                    placeholder="tu@email.com"
                                />
                            </div>
                        </div>

                        <!-- Teléfono -->
                        <div>
                            <label for="telefono" class="block text-sm font-semibold text-night mb-2">Teléfono</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <Phone class="w-5 h-5 text-gray-400" />
                                </div>
                                <input
                                    type="tel"
                                    id="telefono"
                                    name="telefono"
                                    required
                                    class="w-full pl-12 pr-4 py-3.5 border-2 border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-black focus:border-black transition-all"
                                    placeholder="811 123 4567"
                                />
                            </div>
                        </div>

                        <!-- Contraseña -->
                        <div>
                            <label for="password" class="block text-sm font-semibold text-night mb-2">Contraseña</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <Lock class="w-5 h-5 text-gray-400" />
                                </div>
                                <input
                                    type="password"
                                    id="password"
                                    name="password"
                                    required
                                    minlength="6"
                                    class="w-full pl-12 pr-4 py-3.5 border-2 border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-black focus:border-black transition-all"
                                    placeholder="••••••••"
                                />
                            </div>
                            <p class="text-xs text-night/50 mt-1.5">Mínimo 6 caracteres</p>
                        </div>

                        <!-- Confirmar contraseña -->
                        <div>
                            <label for="confirmPassword" class="block text-sm font-semibold text-night mb-2">Confirmar contraseña</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <Lock class="w-5 h-5 text-gray-400" />
                                </div>
                                <input
                                    type="password"
                                    id="confirmPassword"
                                    name="confirmPassword"
                                    required
                                    minlength="6"
                                    class="w-full pl-12 pr-4 py-3.5 border-2 border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-black focus:border-black transition-all"
                                    placeholder="••••••••"
                                />
                            </div>
                        </div>

                        <!-- Submit -->
                        <button
                            type="submit"
                            id="submit-button"
                            class="w-full py-4 bg-black text-white rounded-xl font-bold text-lg hover:bg-gray-800 active:scale-[0.98] transition-all disabled:opacity-50 disabled:cursor-not-allowed disabled:active:scale-100 mt-6"
                        >
                            Crear cuenta
                        </button>
                    </form>

                    <!-- Divider -->
                    <div class="relative my-8">
                        <div class="absolute inset-0 flex items-center">
                            <div class="w-full border-t border-gray-200"></div>
                        </div>
                        <div class="relative flex justify-center text-sm">
                            <span class="px-4 bg-white text-gray-500">¿Ya tienes cuenta?</span>
                        </div>
                    </div>

                    <!-- Login link -->
                    <a href="/login" class="block w-full py-3.5 border-2 border-black text-black rounded-xl font-semibold text-center hover:bg-black hover:text-white transition-all">
                        Iniciar sesión
                    </a>
                </div>
            </div>

            <!-- Footer text -->
            <p class="text-center text-sm text-night/50 mt-8">
                Al crear una cuenta, aceptas nuestros términos y condiciones
            </p>
        </div>
    </section>
</AuthLayout>

<script>
  const form = document.getElementById('registerForm') as HTMLFormElement;
  const errorDiv = document.getElementById('error-message');
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (errorDiv) {
      errorDiv.classList.add('hidden');
      const errorText = errorDiv.querySelector('p');
      if (errorText) errorText.textContent = '';
    }

    const formData = new FormData(form);
    const password = formData.get('password') as string;
    const confirmPassword = formData.get('confirmPassword') as string;

    if (password !== confirmPassword) {
      if (errorDiv) {
        const errorText = errorDiv.querySelector('p');
        if (errorText) {
          errorText.textContent = 'Las contraseñas no coinciden';
        }
        errorDiv.classList.remove('hidden');
      }
      return;
    }

    submitButton.disabled = true;
    const originalText = submitButton.textContent;
    submitButton.textContent = 'Creando cuenta...';

    const data = {
      nombre: formData.get('nombre'),
      email: formData.get('email'),
      telefono: formData.get('telefono'),
      password: formData.get('password')
    };

    try {
      const response = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      const result = await response.json();

      if (!response.ok) {
        throw new Error(result.error || 'Error al crear la cuenta');
      }

      window.location.href = '/';
    } catch (error) {
      submitButton.disabled = false;
      submitButton.textContent = originalText;

      if (errorDiv) {
        const errorText = errorDiv.querySelector('p');
        if (errorText) {
          errorText.textContent = error instanceof Error ? error.message : 'Error al crear cuenta';
        }
        errorDiv.classList.remove('hidden');
      }
    }
  });
</script>