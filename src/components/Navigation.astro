---
import { Mountain, Menu, X, User, Calendar, LogOut, Phone } from '@lucide/astro';
import { getUserFromCookies } from '../lib/auth';

const user = getUserFromCookies(Astro.cookies);
const currentPath = Astro.url.pathname;

const navLinks = [
    { href: '/#cabana', label: 'La Cabaña' },
    { href: '/#amenidades', label: 'Amenidades' },
    { href: '/#precios', label: 'Precios' },
    { href: '/#galeria', label: 'Galería' },
    { href: '/#ubicacion', label: 'Ubicación' }
];
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-lg border-b border-gray-200/50 transition-all duration-300 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-20">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-3 group">
                <img
                    src="/logo.png"
                    alt="Quinta El Cielo Logo"
                    class="w-12 h-12 object-contain"
                />
                <div class="hidden md:block">
                    <div class="font-bold text-lg text-night group-hover:text-forest transition-colors duration-300">
                        Quinta El Cielo
                    </div>
                    <div class="text-xs text-night/50 -mt-1">Sierra de Arteaga</div>
                </div>
            </a>

            <!-- Desktop Navigation -->
            <div class="hidden lg:flex items-center gap-1">
                {navLinks.map((link) => (
                    <a
                        href={link.href}
                        class="relative px-4 py-2 text-sm font-medium text-night/70 hover:text-forest transition-colors duration-200 group"
                    >
                        <span class="relative z-10">{link.label}</span>
                        <div class="absolute inset-0 bg-forest/5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200"></div>
                    </a>
                ))}
            </div>

            <!-- User Menu / Login -->
            <div class="hidden lg:flex items-center gap-3">
                <a href="tel:+528110000000" class="flex items-center gap-2 px-4 py-2 text-sm text-night/60 hover:text-forest transition-colors group">
                    <Phone class="w-4 h-4 group-hover:rotate-12 transition-transform duration-300" />
                    <span class="font-medium">Contacto</span>
                </a>

                {user ? (
                    <div class="relative group">
                        <button class="flex items-center gap-2 px-4 py-2 bg-bone rounded-full border border-forest/10 hover:border-forest/30 transition-all duration-200 group-hover:shadow-md">
                            <div class="w-8 h-8 bg-gradient-forest rounded-full flex items-center justify-center">
                                <User class="w-4 h-4 text-bone" />
                            </div>
                            <span class="text-sm font-medium text-night">{user.nombre.split(" ")[0]}</span>
                        </button>

                        <!-- Dropdown Menu -->
                        <div class="absolute right-0 mt-3 w-52 bg-white rounded-2xl shadow-xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 overflow-hidden">
                            <div class="p-3 bg-gradient-to-r from-forest/5 to-sunset/5 border-b border-gray-100">
                                <p class="text-sm font-semibold text-night">{user.nombre}</p>
                                <p class="text-xs text-night/50">{user.email}</p>
                            </div>
                            <a href="/mis-reservas" class="flex items-center gap-3 px-4 py-3 text-sm text-night hover:bg-bone transition-colors group/item">
                                <Calendar class="w-4 h-4 text-forest group-hover/item:scale-110 transition-transform" />
                                <span class="font-medium">Mis reservas</span>
                            </a>
                            <form action="/api/auth/logout" method="POST" class="border-t border-gray-100">
                                <button type="submit" class="w-full flex items-center gap-3 px-4 py-3 text-sm text-night hover:bg-red-50 transition-colors text-left group/item">
                                    <LogOut class="w-4 h-4 text-red-500 group-hover/item:translate-x-1 transition-transform" />
                                    <span class="font-medium text-red-600">Cerrar sesión</span>
                                </button>
                            </form>
                        </div>
                    </div>
                ) : (
                    <>
                        <a href="/login" class="px-4 py-2 text-sm font-medium text-night/70 hover:text-forest transition-colors">
                            Iniciar sesión
                        </a>
                        <a href="/reservar" class="px-6 py-2.5 bg-gradient-sunset text-white bg-black rounded-full text-sm font-semibold hover:shadow-lg hover:scale-105 transition-all duration-300">
                            Reservar ahora
                        </a>
                    </>
                )}
            </div>

            <!-- Mobile Menu Button -->
            <button
                id="mobile-menu-btn"
                class="lg:hidden p-2.5 rounded-lg bg-bone hover:bg-gray-100 transition-colors"
                aria-label="Toggle menu"
            >
                <Menu id="menu-icon" class="w-6 h-6 text-night" />
                <X id="close-icon" class="w-6 h-6 text-night hidden" />
            </button>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="lg:hidden hidden bg-white border-t border-gray-200 shadow-lg">
        <div class="max-w-7xl mx-auto px-4 py-6 space-y-1">
            {navLinks.map((link) => (
                <a
                    href={link.href}
                    class="block px-4 py-3 text-base font-medium text-night/70 hover:text-forest hover:bg-forest/5 rounded-xl transition-all duration-200 active:scale-95"
                >
                    {link.label}
                </a>
            ))}

            <div class="pt-4 mt-4 border-t border-gray-200 space-y-2">
                {user ? (
                    <>
                        <div class="px-4 py-2 bg-gradient-to-r from-forest/5 to-sunset/5 rounded-xl mb-3">
                            <p class="text-sm font-semibold text-night">{user.nombre}</p>
                            <p class="text-xs text-night/50">{user.email}</p>
                        </div>
                        <a href="/mis-reservas" class="flex items-center gap-3 px-4 py-3 text-base font-medium text-night/70 hover:text-forest hover:bg-forest/5 rounded-xl transition-colors">
                            <Calendar class="w-5 h-5" />
                            Mis reservas
                        </a>
                        <form action="/api/auth/logout" method="POST">
                            <button type="submit" class="w-full flex items-center gap-3 px-4 py-3 text-base font-medium text-red-600 hover:bg-red-50 rounded-xl transition-colors text-left">
                                <LogOut class="w-5 h-5" />
                                Cerrar sesión
                            </button>
                        </form>
                    </>
                ) : (
                    <>
                        <a href="/login" class="block px-4 py-3 text-center text-base font-medium text-night/70 hover:bg-gray-100 rounded-xl transition-colors">
                            Iniciar sesión
                        </a>
                        <a href="/reservar" class="block px-4 py-3 text-center bg-gradient-sunset text-white rounded-xl font-semibold hover:shadow-lg transition-all active:scale-95">
                            Reservar ahora
                        </a>
                    </>
                )}
            </div>
        </div>
    </div>
</nav>

<style>
    #main-nav {
        z-index: 9999;
    }

    #main-nav.scrolled {
        background: rgba(255, 255, 255, 0.98);
        box-shadow: 0 8px 32px rgba(15, 30, 61, 0.08);
        border-bottom-color: rgba(45, 80, 22, 0.1);
    }

    /* Animate mobile menu */
    #mobile-menu {
        animation: slideDown 0.3s ease-out;
    }

    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    // Handle scroll
    const nav = document.getElementById('main-nav');

    window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
            nav?.classList.add('scrolled');
        } else {
            nav?.classList.remove('scrolled');
        }
    });

    // Handle mobile menu
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    mobileMenuBtn?.addEventListener('click', () => {
        const isOpen = !mobileMenu?.classList.contains('hidden');

        if (isOpen) {
            mobileMenu?.classList.add('hidden');
            menuIcon?.classList.remove('hidden');
            closeIcon?.classList.add('hidden');
        } else {
            mobileMenu?.classList.remove('hidden');
            menuIcon?.classList.add('hidden');
            closeIcon?.classList.remove('hidden');
        }
    });

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                // Close mobile menu if open
                if (!mobileMenu?.classList.contains('hidden')) {
                    mobileMenu?.classList.add('hidden');
                    menuIcon?.classList.remove('hidden');
                    closeIcon?.classList.add('hidden');
                }
            }
        });
    });
</script>
