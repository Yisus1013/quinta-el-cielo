---
import { getUserFromCookies } from '../lib/auth';

const user = getUserFromCookies(Astro.cookies);
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/cabana', label: 'Experiencia' },
  { href: '/precios', label: 'Precios' },
  { href: '/ubicacion', label: 'Ubicación' }
];
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 nav-container">
  <div class="container-fluid">
    <div class="nav-inner">
      <!-- Logo -->
      <a href="/" class="logo-link">
        <span class="logo-text">Palapa</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="nav-links">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'nav-link',
              currentPath === link.href && 'nav-link--active'
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA -->
      <div class="nav-actions">
        {user ? (
          <>
            <a href="/perfil" class="user-badge">
              {user.nombre.split(' ')[0]}
            </a>
            <a href="/reservar" class="cta-button">
              Reservar
            </a>
          </>
        ) : (
          <>
            <a href="/login" class="nav-link">
              Acceder
            </a>
            <a href="/reservar" class="cta-button">
              Reservar
            </a>
          </>
        )}
      </div>

      <!-- Mobile Menu Button -->
      <button class="mobile-menu-btn" aria-label="Menu">
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu">
    <div class="mobile-menu-content">
      <div class="mobile-links">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'mobile-link',
              currentPath === link.href && 'mobile-link--active'
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>
      <div class="mobile-actions">
        {user ? (
          <>
            <a href="/perfil" class="mobile-link">Perfil</a>
            <form action="/api/auth/logout" method="POST">
              <button type="submit" class="mobile-link">Salir</button>
            </form>
          </>
        ) : (
          <a href="/login" class="mobile-link">Acceder</a>
        )}
        <a href="/reservar" class="mobile-cta">Reservar Ahora</a>
      </div>
    </div>
  </div>
</nav>

<style>
  /* Navigation Container */
  .nav-container {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-container.scrolled {
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 1px 40px rgba(0, 0, 0, 0.03);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
    transition: height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .scrolled .nav-inner {
    height: 64px;
  }

  /* Logo */
  .logo-link {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #000;
    transition: opacity 0.2s;
  }

  .logo-link:hover {
    opacity: 0.7;
  }

  /* Desktop Navigation */
  .nav-links {
    display: none;
    align-items: center;
    gap: 3rem;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  @media (min-width: 1024px) {
    .nav-links {
      display: flex;
    }
  }

  .nav-link {
    font-size: 0.938rem;
    font-weight: 400;
    color: #737373;
    position: relative;
    transition: color 0.2s;
    letter-spacing: 0.01em;
  }

  .nav-link:hover {
    color: #000;
    opacity: 1;
  }

  .nav-link--active {
    color: #000;
    font-weight: 500;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 0;
    height: 1px;
    background: #000;
    transition: width 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-link:hover::after,
  .nav-link--active::after {
    width: 100%;
  }

  /* Nav Actions */
  .nav-actions {
    display: none;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .nav-actions {
      display: flex;
    }
  }

  .user-badge {
    font-size: 0.938rem;
    font-weight: 500;
    color: #000;
    padding: 0.5rem 1rem;
    border-radius: 100px;
    background: #f5f5f5;
    transition: all 0.2s;
  }

  .user-badge:hover {
    background: #e5e5e5;
    opacity: 1;
  }

  .cta-button {
    font-size: 0.938rem;
    font-weight: 500;
    color: #fff;
    background: #000;
    padding: 0.625rem 1.5rem;
    border-radius: 100px;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .cta-button:hover {
    background: #171717;
    transform: translateY(-1px);
    opacity: 1;
  }

  /* Mobile Menu Button */
  .mobile-menu-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 24px;
    height: 24px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  @media (min-width: 1024px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  .mobile-menu-btn span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: #000;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-menu-btn span:first-child {
    transform: translateY(-3px);
  }

  .mobile-menu-btn span:last-child {
    transform: translateY(3px);
  }

  .mobile-menu-btn.active span:first-child {
    transform: rotate(45deg);
  }

  .mobile-menu-btn.active span:last-child {
    transform: rotate(-45deg);
  }

  /* Mobile Menu */
  .mobile-menu {
    position: fixed;
    top: 80px;
    left: 0;
    right: 0;
    background: #fff;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    transform: translateY(-100%);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    max-height: calc(100vh - 80px);
    overflow-y: auto;
  }

  .mobile-menu.active {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu-content {
    padding: 2rem 1.5rem;
  }

  .mobile-links {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 2rem;
  }

  .mobile-link {
    font-size: 1.125rem;
    font-weight: 400;
    color: #737373;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    transition: color 0.2s;
  }

  .mobile-link:hover {
    color: #000;
  }

  .mobile-link--active {
    color: #000;
    font-weight: 500;
  }

  .mobile-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 1rem;
  }

  .mobile-cta {
    display: inline-block;
    text-align: center;
    font-size: 1rem;
    font-weight: 500;
    color: #fff;
    background: #000;
    padding: 1rem 2rem;
    border-radius: 100px;
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .nav-inner {
      height: 64px;
    }

    .scrolled .nav-inner {
      height: 56px;
    }

    .mobile-menu {
      top: 64px;
    }
  }
</style>

<script>
  // Scroll behavior
  let lastScrollY = 0;
  const nav = document.getElementById('main-nav');

  window.addEventListener('scroll', () => {
    const currentScrollY = window.scrollY;

    if (currentScrollY > 50) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }

    lastScrollY = currentScrollY;
  });

  // Mobile menu toggle
  const mobileMenuBtn = document.querySelector('.mobile-menu-btn');
  const mobileMenu = document.querySelector('.mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenuBtn.classList.toggle('active');
    mobileMenu?.classList.toggle('active');
    document.body.style.overflow = mobileMenu?.classList.contains('active') ? 'hidden' : '';
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenuBtn?.classList.remove('active');
      mobileMenu?.classList.remove('active');
      document.body.style.overflow = '';
    });
  });
</script>