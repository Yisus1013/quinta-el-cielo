---
import { MapPin, Clock, Navigation } from '@lucide/astro';
---

<section id="ubicacion" class="py-20 md:py-32 bg-gradient-to-b from-bone to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="text-center mb-16">
            <span class="text-sm font-semibold text-sunset uppercase tracking-wider">Ubicación</span>
            <h2 class="mt-4 text-4xl md:text-5xl font-bold text-night">
                Fácil acceso desde Monterrey
            </h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- Map -->
            <div class="aspect-video rounded-2xl overflow-hidden shadow-xl">
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3595.123!2d-100.6137!3d25.5842!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjXCsDM1JzAzLjEiTiAxMDDCsDM2JzQ5LjMiVw!5e0!3m2!1sen!2smx!4v1234567890"
                    width="100%"
                    height="100%"
                    style="border:0;"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                ></iframe>
            </div>

            <!-- Info -->
            <div class="space-y-6">
                <div class="flex gap-4">
                    <div class="flex-shrink-0 w-12 h-12 bg-forest/10 rounded-lg flex items-center justify-center">
                        <MapPin class="w-6 h-6 text-forest" />
                    </div>
                    <div>
                        <h3 class="font-semibold text-night mb-1">Ubicación</h3>
                        <p class="text-night/70">Sierra de Arteaga, Coahuila</p>
                        <p class="text-sm text-night/50">A 3,550 metros sobre el nivel del mar</p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div class="flex-shrink-0 w-12 h-12 bg-sunset/10 rounded-lg flex items-center justify-center">
                        <Clock class="w-6 h-6 text-sunset" />
                    </div>
                    <div>
                        <h3 class="font-semibold text-night mb-1">Tiempo de viaje</h3>
                        <p class="text-night/70">80 minutos desde el centro de Monterrey</p>
                        <p class="text-sm text-night/50">Aproximadamente 90 km</p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div class="flex-shrink-0 w-12 h-12 bg-forest/10 rounded-lg flex items-center justify-center">
                        <Navigation class="w-6 h-6 text-forest" />
                    </div>
                    <div>
                        <h3 class="font-semibold text-night mb-1">Acceso</h3>
                        <p class="text-night/70">Camino de concreto hidráulico</p>
                        <p class="text-sm text-night/50">Accesible para cualquier tipo de vehículo</p>
                    </div>
                </div>

                <div class="mt-8 p-6 bg-bone rounded-xl">
                    <h4 class="font-semibold text-night mb-2">Indicaciones</h4>
                    <ol class="space-y-2 text-sm text-night/70">
                        <li>1. Desde Monterrey, toma la carretera a Saltillo</li>
                        <li>2. Desviación hacia Arteaga (señalizado)</li>
                        <li>3. Continúa hacia Sierra de Arteaga</li>
                        <li>4. Sigue las indicaciones hacia Quinta El Cielo</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</section>