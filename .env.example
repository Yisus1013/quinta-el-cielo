# Turso Database (Producción)
# Obtener en: https://turso.tech/
# 1. Crea una cuenta: turso auth signup
# 2. Crea una DB: turso db create palapa-el-sabino
# 3. Obtén URL: turso db show palapa-el-sabino --url
# 4. Obtén token: turso db tokens create palapa-el-sabino
ASTRO_DATABASE_FILE=libsql://your-db-url.turso.io
ASTRO_DB_AUTH_TOKEN=your_turso_auth_token_here

# JWT Secret (genera uno aleatorio seguro)
# Puedes usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_secret_key_here

# URL del sitio (cambiar en producción)
SITE_URL=http://localhost:4321
