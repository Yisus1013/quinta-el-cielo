# Astro DB con Turso (Producción)
# Obtener en: https://turso.tech/
# 1. Instala Turso CLI: npm install -g @turso/cli
# 2. Autentícate: turso auth signup
# 3. Crea una DB: turso db create palapa-el-sabino
# 4. Obtén URL: turso db show palapa-el-sabino --url
# 5. Obtén token: turso db tokens create palapa-el-sabino
# 6. Combina URL y token como se muestra abajo:
# NOTA: Para desarrollo local, comenta esta línea y Astro DB usará SQLite automáticamente
ASTRO_DB_REMOTE_URL=libsql://your-db-name.turso.io?authToken=your_turso_auth_token_here

# JWT Secret (genera uno aleatorio seguro)
# Puedes usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_secret_key_here

# URL del sitio (cambiar en producción)
SITE_URL=http://localhost:4321
